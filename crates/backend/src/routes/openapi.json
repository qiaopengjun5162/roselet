{
  "openapi": "3.0.3",
  "info": {
    "title": "Roselet API",
    "description": "社区破冰互动 Web 应用 API",
    "version": "1.0.0"
  },
  "servers": [{ "url": "/api" }],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "用户注册",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RegisterRequest" } } }
        },
        "responses": {
          "200": { "description": "注册成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "400": { "description": "参数错误" }
        }
      }
    },
    "/auth/deactivate": {
      "post": {
        "tags": ["Auth"],
        "summary": "注销账号",
        "description": "将账号标记为软删除并进入 30 天冷却期；冷却期内可用原昵称恢复，过期后旧昵称会匿名化并释放。",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": false,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DeactivateAccountRequest" } } }
        },
        "responses": {
          "200": { "description": "进入冷却期", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DeactivateAccountResponse" } } } },
          "401": { "description": "未认证" }
        }
      }
    },
    "/user/profile": {
      "get": {
        "tags": ["User"],
        "summary": "获取用户资料",
        "security": [{ "Bearer": [] }],
        "responses": {
          "200": { "description": "成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserProfile" } } } },
          "403": { "description": "未认证" }
        }
      }
    },
    "/rose": {
      "post": {
        "tags": ["Rose"],
        "summary": "种一朵玫瑰",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateRose" } } }
        },
        "responses": {
          "200": { "description": "创建成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RoseResponse" } } } },
          "400": { "description": "参数错误" }
        }
      }
    },
    "/rose/{id}": {
      "get": {
        "tags": ["Rose"],
        "summary": "获取单朵玫瑰",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RoseResponse" } } } },
          "404": { "description": "不存在" }
        }
      },
      "put": {
        "tags": ["Rose"],
        "summary": "编辑玫瑰",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateRose" } } } },
        "responses": {
          "200": { "description": "成功" },
          "403": { "description": "无权操作" },
          "404": { "description": "不存在" }
        }
      },
      "delete": {
        "tags": ["Rose"],
        "summary": "删除玫瑰",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "删除成功" },
          "403": { "description": "无权操作" },
          "404": { "description": "不存在" }
        }
      }
    },
    "/rose/{id}/like": {
      "post": {
        "tags": ["Like"],
        "summary": "点赞/取消点赞",
        "security": [{ "Bearer": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LikeResponse" } } } },
          "403": { "description": "未认证" }
        }
      }
    },
    "/garden": {
      "get": {
        "tags": ["Garden"],
        "summary": "获取花圃",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "color", "in": "query", "schema": { "type": "string", "enum": ["red", "white", "yellow"] } }
        ],
        "responses": {
          "200": { "description": "成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedRoseResponse" } } } }
        }
      }
    },
    "/my/roses": {
      "get": {
        "tags": ["My"],
        "summary": "获取我的花圃",
        "security": [{ "Bearer": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "成功" },
          "403": { "description": "未认证" }
        }
      }
    },
    "/feedback": {
      "post": {
        "tags": ["Feedback"],
        "summary": "提交反馈",
        "description": "匿名和登录用户均可提交反馈；登录用户会自动关联 user_id。",
        "security": [{ "Bearer": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FeedbackRequest" } } }
        },
        "responses": {
          "201": { "description": "提交成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FeedbackResponse" } } } },
          "400": { "description": "参数错误" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Bearer": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["nickname"],
        "properties": {
          "nickname": { "type": "string", "maxLength": 50 },
          "passphrase": { "type": "string", "maxLength": 100, "nullable": true }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "refresh_token": { "type": "string" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "DeactivateAccountRequest": {
        "type": "object",
        "properties": {
          "reason": { "type": "string", "nullable": true }
        }
      },
      "DeactivateAccountResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "restore_deadline": { "type": "string", "format": "date-time" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "nickname": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "deleted_at": { "type": "string", "format": "date-time", "nullable": true },
          "deletion_reason": { "type": "string", "nullable": true }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "user": { "$ref": "#/components/schemas/User" },
          "total_roses": { "type": "integer" },
          "red_count": { "type": "integer" },
          "white_count": { "type": "integer" },
          "yellow_count": { "type": "integer" }
        }
      },
      "CreateRose": {
        "type": "object",
        "required": ["color"],
        "properties": {
          "color": { "type": "string", "enum": ["red", "white", "yellow"] },
          "gratitude": { "type": "string", "maxLength": 500 },
          "anxiety": { "type": "string", "maxLength": 500 },
          "hope": { "type": "string", "maxLength": 500 },
          "is_private": { "type": "boolean" },
          "recipient_nickname": { "type": "string", "nullable": true }
        }
      },
      "UpdateRose": {
        "type": "object",
        "properties": {
          "color": { "type": "string", "enum": ["red", "white", "yellow"] },
          "gratitude": { "type": "string", "maxLength": 500 },
          "anxiety": { "type": "string", "maxLength": 500 },
          "hope": { "type": "string", "maxLength": 500 }
        }
      },
      "RoseResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "color": { "type": "string" },
          "gratitude": { "type": "string" },
          "anxiety": { "type": "string" },
          "hope": { "type": "string" },
          "user_id": { "type": "string", "format": "uuid" },
          "nickname": { "type": "string" },
          "like_count": { "type": "integer" },
          "ai_reply": { "type": "string" },
          "is_private": { "type": "boolean" },
          "recipient_nickname": { "type": "string", "nullable": true },
          "is_gift": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "LikeResponse": {
        "type": "object",
        "properties": {
          "liked": { "type": "boolean" },
          "like_count": { "type": "integer" }
        }
      },
      "FeedbackRequest": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": { "type": "string", "minLength": 5, "maxLength": 500 }
        }
      },
      "FeedbackResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" }
        }
      },
      "PaginatedRoseResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/RoseResponse" } },
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "per_page": { "type": "integer" }
        }
      }
    }
  }
}
